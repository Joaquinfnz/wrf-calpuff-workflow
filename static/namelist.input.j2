# =============================================================================
# namelist.input — Jinja2 Template
# Parametrizaciones fisicas validadas para sur de Chile (Falvey / Schmitz)
# Requisito SEA: debe entregarse en la evaluacion
# =============================================================================
&time_control
 run_days                 = {{ run_days }},
 run_hours                = {{ run_hours }},
 run_minutes              = 0,
 run_seconds              = 0,
 start_year               = {% for d in range(wrf.max_dom) %}{{ inicio_year }},{% endfor %}
 start_month              = {% for d in range(wrf.max_dom) %}{{ inicio_month }},{% endfor %}
 start_day                = {% for d in range(wrf.max_dom) %}{{ inicio_day }},{% endfor %}
 start_hour               = {% for d in range(wrf.max_dom) %}{{ inicio_hour }},{% endfor %}
 start_minute             = {% for d in range(wrf.max_dom) %}{{ inicio_minute }},{% endfor %}
 start_second             = {% for d in range(wrf.max_dom) %}{{ inicio_second }},{% endfor %}
 end_year                 = {% for d in range(wrf.max_dom) %}{{ fin_year }},{% endfor %}
 end_month                = {% for d in range(wrf.max_dom) %}{{ fin_month }},{% endfor %}
 end_day                  = {% for d in range(wrf.max_dom) %}{{ fin_day }},{% endfor %}
 end_hour                 = {% for d in range(wrf.max_dom) %}{{ fin_hour }},{% endfor %}
 end_minute               = {% for d in range(wrf.max_dom) %}{{ fin_minute }},{% endfor %}
 end_second               = {% for d in range(wrf.max_dom) %}{{ fin_second }},{% endfor %}
 interval_seconds         = {{ wrf.interval_seconds }},
 input_from_file          = {% for d in range(wrf.max_dom) %}.true.,{% endfor %}
 history_interval         = {% for h in wrf.history_interval %}{{ h }},{% endfor %}
 frames_per_outfile       = {% for f in wrf.frames_per_outfile %}{{ f }},{% endfor %}
 restart                  = .false.,
 restart_interval         = {{ wrf.restart_interval }},
 io_form_history          = 2,
 io_form_restart          = 2,
 io_form_input            = 2,
 io_form_boundary         = 2,
 debug_level              = 0,
/

&domains
 time_step                = {{ wrf.dominios.d01.resolution_km * 6 }},
 max_dom                  = {{ wrf.max_dom }},
 e_we                     = {% for d in wrf.dominios.values() | list %}{{ d.e_we }},{% endfor %}
 e_sn                     = {% for d in wrf.dominios.values() | list %}{{ d.e_sn }},{% endfor %}
 e_vert                   = {% for d in range(wrf.max_dom) %}{{ wrf.e_vert }},{% endfor %}
 p_top_requested          = {{ wrf.p_top_requested }},
 num_metgrid_levels       = {{ wrf.num_metgrid_levels }},
 num_metgrid_soil_levels  = 4,
 dx                       = {% for d in wrf.dominios.values() | list %}{{ d.resolution_km * 1000 }},{% endfor %}
 dy                       = {% for d in wrf.dominios.values() | list %}{{ d.resolution_km * 1000 }},{% endfor %}
 grid_id                  = {% for d in range(wrf.max_dom) %}{{ loop.index }},{% endfor %}
 parent_id                = {% for d in wrf.dominios.values() | list %}{{ d.parent_id }},{% endfor %}
 i_parent_start           = {% for d in wrf.dominios.values() | list %}{{ d.i_parent_start }},{% endfor %}
 j_parent_start           = {% for d in wrf.dominios.values() | list %}{{ d.j_parent_start }},{% endfor %}
 parent_grid_ratio        = {% for d in wrf.dominios.values() | list %}{{ d.parent_grid_ratio }},{% endfor %}
 parent_time_step_ratio   = {% for d in wrf.dominios.values() | list %}{{ d.parent_grid_ratio }},{% endfor %}
 feedback                 = 1,
 smooth_option            = 0,
/

&physics
 mp_physics               = {{ wrf.physics.mp_physics | join(', ') }},
 cu_physics               = {{ wrf.physics.cu_physics | join(', ') }},
 bl_pbl_physics           = {{ wrf.physics.bl_pbl_physics | join(', ') }},
 sf_sfclay_physics        = {{ wrf.physics.sf_sfclay_physics | join(', ') }},
 sf_surface_physics       = {{ wrf.physics.sf_surface_physics | join(', ') }},
 ra_sw_physics            = {{ wrf.physics.ra_sw_physics | join(', ') }},
 ra_lw_physics            = {{ wrf.physics.ra_lw_physics | join(', ') }},
 radt                     = 27,9,3,
 bldt                     = 0,0,0,
 cudt                     = 5,5,0,
 mp_zero_out              = 2,
 co2tf                    = 0,
 iz0tlnd                  = 0,
 sf_urban_physics         = 0,0,0,
/

&fdda
/

&dynamics
 w_damping                = 1,
 diff_opt                 = 1,1,1,
 km_opt                   = 4,4,4,
 diff_6th_opt             = 0,0,0,
 diff_6th_factor          = 0.12,0.12,0.12,
 base_temp                = 290.,
 damp_opt                 = 3,
 zdamp                    = 5000.,5000.,5000.,
 dampcoef                 = 0.2,0.2,0.2,
 khdif                    = 0,0,0,
 kvdif                    = 0,0,0,
 non_hydrostatic          = .true.,.true.,.true.,
 moist_adv_opt            = 1,1,1,
 scalar_adv_opt           = 1,1,1,
/

&bdy_control
 spec_bdy_width           = 5,
 spec_zone                = 1,
 relax_zone               = 4,
 spec_exp                 = 0.33,
 specified                = .true.,.false.,.false.,
 nested                   = .false.,.true.,.true.,
/

&namelist_quilt
 nio_tasks_per_group      = 0,
 nio_groups               = 1,
/
