# =============================================================================
# Snakefile — WRF → CALPUFF Workflow
# Pipeline Snakemake: ERA5 → WPS → WRF → CALMET → CALPUFF → Post-proc SEIA
# Soporta corrida continua (default, 5-7 dias) y segmentacion mensual
# =============================================================================

import yaml
import os
from pathlib import Path

configfile: "config.yaml"

with open("config.yaml") as f:
    cfg = yaml.safe_load(f)

PROYECTO      = cfg["proyecto"]["nombre"].replace(" ", "_")
ANIO          = cfg["periodo"]["anio"]
MESES         = cfg["periodo"]["meses"]
SEGMENTACION  = cfg["wrf"].get("segmentacion", "continua")
SPINUP_DIAS   = cfg["wrf"].get("spinup_dias", 3)
OUTPUT_DIR    = f"data/outputs/{PROYECTO}_{ANIO}"
WRF_IMAGE     = cfg["docker"]["wrf_image"]
CALPUFF_IMAGE = cfg["docker"]["calpuff_image"]
RUTAS         = cfg["rutas"]

# ── Modo de corrida ──────────────────────────────────────────────────────────
if SEGMENTACION == "continua":
    # Una sola corrida para todo el año, pero ERA5 se baja por mes
    PERIODO        = str(ANIO)
    ERA5_FILE      = expand(f"data/raw/ERA5_{ANIO}_{{m:02d}}.grib", m=MESES)
    FILE_PREFIX    = f"data/wps/FILE:{ANIO}"
    MET_EM_PATTERN = [f"data/wps/met_em.d{d}.{ANIO}.nc" for d in range(1, 4)]
    WRF_INPUT      = f"data/wrf/wrfinput_d01_{ANIO}"
    WRF_BDY        = f"data/wrf/wrfbdy_d01_{ANIO}"
    WRF_MARKER     = f"data/wrf/.wrf_done_{ANIO}"
    WRF_OUTS       = [WRF_MARKER]
    CALWRF_DONE    = "data/calmet/calwrf_ok"
else:
    # 12 segmentos mensuales con spin-up de 24h cada uno
    PERIODO        = [f"{ANIO}-{m:02d}" for m in MESES]
    ERA5_FILE      = [f"data/raw/ERA5_{ANIO}_{m:02d}.grib" for m in MESES]
    FILE_PREFIX    = f"data/wps/FILE:{{periodo}}"
    MET_EM_PATTERN = [f"data/wps/met_em.d{{d}}.{{periodo}}.nc" for d in range(1, 4)]
    WRF_INPUT      = f"data/wrf/wrfinput_d01_{{periodo}}"
    WRF_BDY        = f"data/wrf/wrfbdy_d01_{{periodo}}"
    WRF_MARKER     = f"data/wrf/wrfout_d01_{{periodo}}_final.nc"
    WRF_OUTS       = [f"data/wrf/wrfout_d01_{ANIO}-{m:02d}_final.nc" for m in MESES]
    CALWRF_DONE    = "data/calmet/calwrf_ok"


# ── Reglas ───────────────────────────────────────────────────────────────────

rule all:
    input:
        f"{OUTPUT_DIR}/tablas/concentraciones_vs_norma.xlsx",
        f"{OUTPUT_DIR}/mapas/isoconcentracion_mp10_24h.png",
        f"{OUTPUT_DIR}/memoria_calculo.md",
        f"{OUTPUT_DIR}/validacion/validacion_wrf.png",


# ── 1. Check de config SEA ──────────────────────────────────────────────────

rule check_config:
    output:
        "data/.check_config_ok"
    shell:
        "python3 workflow/scripts/check_config.py config.yaml && touch {output}"


# ── 2. Descarga ERA5 ────────────────────────────────────────────────────────

rule download_era5:
    input:
        "data/.check_config_ok"
    output:
        ERA5_FILE
    shell:
        "python3 workflow/scripts/download_era5.py config.yaml"


# ── 3. Renderizar namelists ─────────────────────────────────────────────────

rule render_namelists:
    input:
        "data/.check_config_ok"
    output:
        "data/wps/namelist.wps",
        "data/wrf/namelist.input",
        "data/calmet/calmet.inp",
        "data/calpuff/calpuff.inp"
    shell:
        "python3 workflow/scripts/render_namelist.py config.yaml"


# ── 4. Limpiar outputs previos ──────────────────────────────────────────────

rule limpiar:
    input:
        "data/wps/namelist.wps"
    output:
        "data/.limpio"
    shell:
        """
        rm -f data/wps/met_em.d0* data/wps/GRIBFILE.* data/wps/FILE:*
        rm -f data/wrf/rsl.* data/wrf/wrfinput_d0* data/wrf/wrfbdy_d0*
        touch {output}
        """


# ── 5. WPS: geogrid → ungrib → metgrid ─────────────────────────────────────

rule geogrid:
    input:
        "data/wps/namelist.wps",
        "data/.limpio"
    output:
        expand("data/wps/geo_em.d{{d}}.nc", d=[1, 2, 3])
    shell:
        """
        docker run --rm \
            -v $(pwd)/data:/data \
            -v {RUTAS[wps_geog]}:/data/WPS_GEOG \
            {WRF_IMAGE} \
            bash -o pipefail -c "cd /data/wps && ln -sf /data/WPS_GEOG . && geogrid.exe" \
            2>&1 | tee data/wps/geogrid.log
        """


rule ungrib:
    input:
        ERA5_FILE,
        "data/wps/namelist.wps"
    output:
        FILE_PREFIX
    shell:
        """
        # Enlazar la Vtable de ERA5 (pl+sfc) que ungrib necesita
        cp static/Vtable.ERA5 data/wps/Vtable
        docker run --rm \
            -v $(pwd)/data:/data \
            {WRF_IMAGE} \
            bash -o pipefail -c "cd /data/wps && \
                /opt/wps/link_grib.csh ../raw/ERA5_*.grib && \
                ungrib.exe 2>&1 | tee ungrib.log"
        """


rule metgrid:
    input:
        rules.geogrid.output,
        FILE_PREFIX,
        "data/wps/namelist.wps"
    output:
        MET_EM_PATTERN
    shell:
        """
        docker run --rm \
            -v $(pwd)/data:/data \
            {WRF_IMAGE} \
            bash -o pipefail -c "cd /data/wps && metgrid.exe 2>&1 | tee metgrid.log"
        """


# ── 6. WRF: real → wrf (corrida continua, checkpoint cada 6h) ───────────────

rule real:
    input:
        MET_EM_PATTERN,
        "data/wrf/namelist.input"
    output:
        WRF_INPUT,
        WRF_BDY
    shell:
        """
        docker run --rm \
            -v $(pwd)/data:/data \
            {WRF_IMAGE} \
            bash -o pipefail -c "cp /data/wps/met_em* /data/wrf/ && cd /data/wrf && real.exe 2>&1 | tee real.log"
        """


rule wrf:
    input:
        rules.real.output,
        "data/wrf/namelist.input"
    output:
        WRF_MARKER
    params:
        nprocs=cfg["docker"]["build"]["nprocs"],
    shell:
        """
        # Si existe wrfrst previo, WRF arranca desde checkpoint
        # WRF detecta los wrfrst_* automaticamente cuando restart=TRUE en namelist
        docker run --rm \
            -v $(pwd)/data:/data \
            {WRF_IMAGE} \
            bash -o pipefail -c "cd /data/wrf && mpirun --allow-run-as-root -np {params.nprocs} ./wrf.exe 2>&1 | tee wrf.log"

        touch {output}
        echo "[OK] WRF finalizado. wrfout marcado en {output}"
        """


# ── 7. CALWRF: convertir wrfout → inputs CALMET ─────────────────────────────

rule calwrf:
    input:
        WRF_OUTS
    output:
        CALWRF_DONE
    shell:
        """
        docker run --rm \
            -v $(pwd)/data:/data \
            {CALPUFF_IMAGE} \
            bash -o pipefail -c "python3 /opt/calpuff/scripts/calwrf_wrapper.py \
                --wrfout-dir /data/wrf \
                --output-dir /data/calmet \
                --start {cfg['periodo']['inicio']} \
                --end {cfg['periodo']['fin']}"
        touch {output}
        """


# ── 8. CALMET ───────────────────────────────────────────────────────────────

rule calmet:
    input:
        CALWRF_DONE,
        "data/calmet/calmet.inp"
    output:
        "data/calmet/calmet.dat"
    shell:
        """
        docker run --rm \
            -v $(pwd)/data:/data \
            {CALPUFF_IMAGE} \
            bash -o pipefail -c "cd /data/calmet && calmet.exe calmet.inp 2>&1 | tee calmet.log"
        """


# ── 9. CALPUFF ──────────────────────────────────────────────────────────────

rule calpuff:
    input:
        "data/calmet/calmet.dat",
        "data/calpuff/calpuff.inp",
        "emisiones.csv"
    output:
        "data/calpuff/conc.dat"
    shell:
        """
        docker run --rm \
            -v $(pwd)/data:/data \
            -v $(pwd)/emisiones.csv:/data/calpuff/emisiones.csv \
            {CALPUFF_IMAGE} \
            bash -o pipefail -c "cd /data/calpuff && calpuff.exe calpuff.inp 2>&1 | tee calpuff.log"
        """


# ── 10. Validacion WRF vs observaciones ─────────────────────────────────────

rule validar_wrf:
    input:
        WRF_OUTS
    output:
        f"{OUTPUT_DIR}/validacion/validacion_wrf.png"
    shell:
        """
        mkdir -p {OUTPUT_DIR}/validacion
        python3 workflow/scripts/validar_wrf.py config.yaml
        """


# ── 11. Post-procesamiento SEIA ─────────────────────────────────────────────

rule postprocesar_seia:
    input:
        "data/calpuff/conc.dat",
        "receptores.csv",
        "emisiones.csv"
    output:
        f"{OUTPUT_DIR}/tablas/concentraciones_vs_norma.xlsx",
        f"{OUTPUT_DIR}/mapas/isoconcentracion_mp10_24h.png",
        f"{OUTPUT_DIR}/memoria_calculo.md"
    shell:
        """
        mkdir -p {OUTPUT_DIR}/tablas {OUTPUT_DIR}/mapas
        python3 workflow/scripts/postprocesar_seia.py config.yaml
        mkdir -p {OUTPUT_DIR}/namelists
        cp data/wps/namelist.wps data/wrf/namelist.input \
           data/calmet/calmet.inp data/calpuff/calpuff.inp \
           {OUTPUT_DIR}/namelists/
        mkdir -p {OUTPUT_DIR}/calpuff
        cp data/calmet/calmet.dat data/calpuff/conc.dat \
           data/calmet/calmet.log data/calpuff/calpuff.log \
           {OUTPUT_DIR}/calpuff/
        """
